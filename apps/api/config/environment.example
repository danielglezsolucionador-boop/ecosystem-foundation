# Ecosystem Foundation API environment template.
# Copy values into a local .env file or shell environment.
# Do not place real credentials in this template.

ECOSYSTEM_API_ENVIRONMENT=local
ECOSYSTEM_API_SERVICE_NAME=ecosystem-foundation-api
ECOSYSTEM_API_VERSION=0.1.0
ECOSYSTEM_API_COMMIT=local
ECOSYSTEM_API_CORS_ORIGINS=http://localhost:5173
ECOSYSTEM_API_DEBUG=false

# Local default. For Vercel Postgres, configure DATABASE_URL in Vercel instead.
ECOSYSTEM_API_DATABASE_URL=sqlite:///./var/ecosystem_foundation.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# CEREBRO / ARSENAL AI provider preparation.
CEREBRO_LLM_ENABLED=true
CEREBRO_LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ARSENAL_API_BROKER_ENABLED=false
ARSENAL_DEFAULT_PROVIDER=openrouter
ARSENAL_DEFAULT_MODEL=prepared-router-v1

# LinkedIn official OAuth preparation.
# Never configure email/password here. Publication remains disabled in this release.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_POSTING_ENABLED=false

# Control Center initial CEO bootstrap.
# Set to false when the CEO cabin must open directly without email/password.
CONTROL_CENTER_AUTH_ENABLED=true
# Leave unset unless you are provisioning the first real user.
# No default admin is created when any of these values is missing.
CONTROL_CENTER_ADMIN_EMAIL=
CONTROL_CENTER_ADMIN_PASSWORD=
CONTROL_CENTER_ADMIN_NAME=
