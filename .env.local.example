# Ecosystem Foundation local development template.
# Copy to .env.local for personal local use. Do not store real secrets here.

ECOSYSTEM_API_ENVIRONMENT=local
ECOSYSTEM_API_SERVICE_NAME=ecosystem-foundation-api
ECOSYSTEM_API_VERSION=0.1.0
ECOSYSTEM_API_COMMIT=local-dev
ECOSYSTEM_API_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:5173,http://127.0.0.1:5173
ECOSYSTEM_API_DEBUG=true

# Preferred local database: Docker Compose PostgreSQL from docker-compose.yml.
# This port intentionally avoids the common local 5432 port used by other apps.
ECOSYSTEM_API_DATABASE_URL=postgresql://ecosystem_local:ecosystem_local@127.0.0.1:55432/ecosystem_foundation_local?connect_timeout=3

# Optional compatibility alias. ECOSYSTEM_API_DATABASE_URL has priority in this app.
# DATABASE_URL=postgresql://ecosystem_local:ecosystem_local@127.0.0.1:55432/ecosystem_foundation_local?connect_timeout=3

# Local Control Center CEO bootstrap.
# Set to false when the CEO cabin must open directly without email/password.
CONTROL_CENTER_AUTH_ENABLED=true
# Non-sensitive local example only. Replace in your private .env.local if needed.
CONTROL_CENTER_ADMIN_EMAIL=ceo.local@example.com
CONTROL_CENTER_ADMIN_PASSWORD=example-local-control-center-password
CONTROL_CENTER_ADMIN_NAME=Local CEO

# Optional local discovery path for Hermes.
# If unset, scripts use the known local discovery path when it exists.
# HERMES_KNOWLEDGE_CORE_PATH=C:/Users/admin/Documents/Codex/2026-05-20/fase-render-cloud-stabilization-objetivo-inicializar/hermes-knowledge-core
